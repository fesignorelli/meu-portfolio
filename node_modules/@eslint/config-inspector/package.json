{
  "name": "@eslint/config-inspector",
  "type": "module",
  "version": "3.0.4",
  "description": "A visual tool for inspecting and understanding your ESLint flat configs",
  "license": "Apache-2.0",
  "funding": "https://opencollective.com/eslint",
  "homepage": "https://github.com/eslint/config-inspector#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eslint/config-inspector.git"
  },
  "bugs": "https://github.com/eslint/config-inspector/issues",
  "bin": {
    "@eslint/config-inspector": "./bin.mjs",
    "eslint-config-inspector": "./bin.mjs"
  },
  "files": [
    "*.mjs",
    "dist"
  ],
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24"
  },
  "peerDependencies": {
    "eslint": "^8.50.0 || ^9.0.0 || ^10.0.0"
  },
  "dependencies": {
    "ansis": "^4.3.0",
    "cac": "^7.0.0",
    "chokidar": "^5.0.0",
    "devframe": "^0.5.2",
    "jiti": "^2.7.0",
    "tinyglobby": "^0.2.16"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@axe-core/playwright": "^4.11.3",
    "@eslint/config-array": "^0.23.5",
    "@iconify-json/carbon": "^1.2.22",
    "@iconify-json/file-icons": "^1.2.2",
    "@iconify-json/logos": "^1.2.11",
    "@iconify-json/ph": "^1.2.2",
    "@iconify-json/simple-icons": "^1.2.83",
    "@iconify-json/svg-spinners": "^1.2.4",
    "@iconify-json/twemoji": "^1.2.5",
    "@iconify-json/vscode-icons": "^1.2.50",
    "@nodelib/fs.walk": "^3.0.1",
    "@nuxt/eslint": "^1.15.2",
    "@playwright/test": "^1.60.0",
    "@shikijs/langs-precompiled": "^4.1.0",
    "@shikijs/transformers": "^4.1.0",
    "@typescript-eslint/utils": "^8.59.4",
    "@unocss/eslint-config": "^66.7.0",
    "@unocss/nuxt": "^66.7.0",
    "@vueuse/nuxt": "^14.3.0",
    "eslint": "^10.4.0",
    "find-up": "^8.0.0",
    "floating-vue": "^5.2.2",
    "fuse.js": "^7.3.0",
    "lint-staged": "^17.0.5",
    "minimatch": "^10.2.5",
    "mlly": "^1.8.2",
    "nuxt": "^4.4.6",
    "pathe": "^2.0.3",
    "rolldown": "^1.0.2",
    "rollup": "^4.60.4",
    "semver": "^7.8.1",
    "shiki": "^4.1.0",
    "simple-git-hooks": "^2.13.1",
    "skills-npm": "^1.1.1",
    "textmate-grammar-glob": "^0.0.1",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7",
    "vue-tsc": "^3.3.1"
  },
  "resolutions": {
    "chokidar": "catalog:",
    "esbuild": "catalog:",
    "nitropack": "catalog:",
    "rolldown": "catalog:",
    "rollup": "catalog:",
    "semver": "catalog:",
    "vite": "catalog:"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  },
  "scripts": {
    "build": "nuxt build && tsdown",
    "dev": "nuxt dev",
    "cli:build": "node bin.mjs build",
    "cli:dev": "pnpm build && node bin.mjs",
    "start": "node bin.mjs",
    "lint": "nuxt prepare && eslint .",
    "test": "vitest",
    "pretest:e2e": "node -e \"process.exit(require('node:fs').existsSync('dist/cli.mjs')?0:1)\" || pnpm build",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "typecheck": "nuxt typecheck"
  }
}